---
interface Props {
  id?: string;
  variant: "prev" | "next" | "close";
  label: string;
  class?: string;
}

const { id, variant, label, class: extraClass = "" } = Astro.props;

const paths: Record<string, string> = {
  prev: "M15 5l-7 7 7 7",
  next: "M9 5l7 7-7 7",
  close: "M6 6l12 12M18 6L6 18",
};
---

<button
  id={id}
  type="button"
  aria-label={label}
  class:list={[
    "rounded-full p-3 text-canvas bg-canvas/20 backdrop-blur-sm outline-1 outline-offset-0 outline-solid outline-canvas/30 transition hover:bg-canvas/30 select-none",
    extraClass,
  ]}
>
  <svg viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current stroke-2">
    <path d={paths[variant]} stroke-linecap="round" stroke-linejoin="round"
    ></path>
  </svg>
</button>
