---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Gallery from "../components/Gallery.astro";
import GlampUnit from "../components/GlampUnit.astro";
import aFrameMain from "../assets/glamps/a-frame/main.jpeg";
---

<Layout>
  <Header />
  <Hero />
  <Gallery />
  <GlampUnit
    name="'La Morada' A-Frame"
    unitType="A-Frame"
    description="Cabaña de dos niveles con ventanales de piso a techo, ideal para 2-4 personas."
    mainPhoto={aFrameMain}
    galleryFolder="a-frame"
    features={[
      { icon: "bed", label: "Cama Queen size" },
      { icon: "sofa", label: "Sofa cama" },
      { icon: "shower", label: "Baño completo" },
      { icon: "minisplit", label: "Mini split" },
      { icon: "kindle", label: "Terraza con fogatero" },
      { icon: "wifi", label: "WiFi" },
    ]}
  />
</Layout>
