---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Gallery from "../components/Gallery.astro";
import GlampUnit from "../components/GlampUnit.astro";
import aFrameMain from "../assets/glamps/a-frame/main.jpeg";
import DomoMain from "../assets/glamps/domo/main.jpg";
import LuminaMain from "../assets/glamps/lumina/main.jpg";
---

<Layout>
  <Header />
  <Hero />
  <Gallery />
  <GlampUnit
    name="'La Morada' A-Frame"
    unitType="A-Frame"
    description="Cabaña de dos niveles con ventanales de piso a techo, ideal para 2-4 personas."
    mainPhoto={aFrameMain}
    galleryFolder="a-frame"
    features={[
      { icon: "bed", label: "Cama Queen size" },
      { icon: "sofa", label: "Sofa cama" },
      { icon: "microwave", label: "Cocineta equipada" },
      { icon: "minisplit", label: "Mini split" },
      { icon: "kindle", label: "Terraza con fogatero" },
      { icon: "shower", label: "Baño completo" },
    ]}
  />
  <GlampUnit
    name="'La Morada' Domo"
    unitType="Domo"
    description="Domo de un nivel, ideal para 2-4 personas."
    mainPhoto={DomoMain}
    galleryFolder="domo"
    features={[
      { icon: "bed", label: "Cama & Sofa cama" },
      { icon: "tub", label: "Tina" },
      { icon: "microwave", label: "Cocineta equipada" },
      { icon: "minisplit", label: "Mini split" },
      { icon: "umbrella", label: "Terraza" },
      { icon: "grid", label: "Red flotante" },
    ]}
  />
  <GlampUnit
    name="'La Morada' Lumina"
    unitType="Lumina"
    description="A-frame de un nivel, ideal para parejas."
    mainPhoto={LuminaMain}
    galleryFolder="lumina"
    features={[
      { icon: "bed", label: "Cama Queen size" },
      { icon: "jacuzzi", label: "Terraza con jacuzzi" },
      { icon: "wine", label: "Botella de vino" },
      { icon: "kindle", label: "Fogata" },
      { icon: "cookie", label: "Kit de S'mores" },
      { icon: "shower", label: "Baño completo" },
    ]}
  />
</Layout>
